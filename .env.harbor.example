HARBOR_USER=your-harbor-username
HARBOR_PASSWORD=your-harbor-password
HARBOR_REGISTRY=harbor.b2metric.com
HARBOR_PROJECT=stc
IMAGE_NAME=b2m-sage-ai
IMAGE_TAG=latest

# Multi-platform buildx settings
BUILD_PLATFORMS=linux/amd64,linux/arm64
BUILDER_NAME=multiarch
DOCKERFILE_PATH=Dockerfile
BUILD_CONTEXT=.

# Docker build arguments
MAGE_EXTRAS=postgres
INSTALL_EXTRA_PY_DEPS=true
INSTALL_MSSQL=false
INSTALL_R=false
INSTALL_SPARKMAGIC=false
